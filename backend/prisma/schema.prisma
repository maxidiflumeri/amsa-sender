generator client {
  provider = "prisma-client-js"
}

//datasource db {
//  provider = "sqlite"
//  url      = "file:./dev.db"
//}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Campaña {
  id         Int        @id @default(autoincrement())
  nombre     String
  createdAt  DateTime   
  enviadoAt  DateTime?
  agendadoAt DateTime? // NUEVO: fecha y hora del agendamiento
  estado     String     @default("pendiente") // nuevo campo
  pausada    Boolean    @default(false) // <-- NUEVO
  templateId Int? // FK opcional
  jobId      String? // 👈 NUEVO
  template   Template?  @relation(fields: [templateId], references: [id])
  contactos  Contacto[]
  reportes   Reporte[]
  archivada  Boolean    @default(false)
  sesiones   String? // JSON.stringified sessionIds
  config     Json? // { batchSize, delayEntreMensajes, delayEntreLotes }
  @@map("Campaña")
}

model Contacto {
  id         Int      @id @default(autoincrement())
  numero     String
  mensaje    String?  @db.Text
  datos      Json? // ⬅️ Acá irán los datos variables del CSV
  campañaId Int
  campaña   Campaña @relation(fields: [campañaId], references: [id])
  @@map("Contacto")
}

model Reporte {
  id         Int       @id @default(autoincrement())
  numero     String
  mensaje    String?   @db.Text
  estado     String
  aniEnvio   String? // <--- este campo
  enviadoAt  DateTime? // nuevo campo
  datos      Json? // ← Nuevo campo para almacenar los datos del contacto (del CSV)
  campaña   Campaña? @relation(fields: [campañaId], references: [id], onDelete: SetNull)
  campañaId Int?
  @@map("Reporte")
}

model Sesion {
  id        Int     @id @default(autoincrement())
  sessionId String  @unique
  estado    String
  ani       String? // nuevo campo opcional
  @@map("Sesion")
}

model Template {
  id        Int        @id @default(autoincrement())
  nombre    String
  contenido String     @db.Text // Ej: "Hola {{nombre}}, tu deuda es de {{deuda}}"
  createdAt DateTime   
  campañas Campaña[] // Relación con campañas
  @@map("Template")
}

model Mensaje {
  id         Int      @id @default(autoincrement())
  numero     String
  campañaId Int? // Puede estar o no vinculado a una campaña
  ani        String
  mensaje    String   @db.Text
  fromMe     Boolean // true = enviado, false = recibido
  fecha      DateTime
  tipo       String? // "texto", "imagen", etc.
  @@map("Mensaje")
}

model CuentaSMTP {
  id        Int             @id @default(autoincrement())
  nombre    String // ej. "Cuenta corporativa"
  host      String
  puerto    Int
  usuario   String
  password  String // se puede cifrar más adelante
  remitente String // nombre del remitente que verá el destinatario
  emailFrom String // dirección de email usada en el "From"
  creadoAt  DateTime
  templates TemplateEmail[]
  @@map("CuentaSMTP")
}

model Rol {
  id       Int       @id @default(autoincrement())
  nombre   String    @unique
  permisos Json      // string[] — ej: ["whatsapp.campanias", "email.reportes"]
  creadoAt DateTime  @default(now())
  usuarios Usuario[]
  @@map("Rol")
}

model Usuario {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  nombre   String
  foto     String?
  rol      String   @default("usuario")  // nombre del rol (sincronizado)
  rolId    Int?
  rolObj   Rol?     @relation(fields: [rolId], references: [id])
  activo   Boolean  @default(true)
  creadoAt DateTime
  @@map("Usuario")
}

model TemplateEmail {
  id           Int             @id @default(autoincrement())
  nombre       String
  asunto       String
  html         String          @db.MediumText
  design       Json
  creadoAt     DateTime
  campanias    CampañaEmail[]
  cuentaSmtpId Int?
  cuentaSmtp   CuentaSMTP?     @relation(fields: [cuentaSmtpId], references: [id], onDelete: SetNull)
  @@map("TemplateEmail")
}

model CampañaEmail {
  id         Int             @id @default(autoincrement())
  nombre     String
  createdAt  DateTime        
  enviadoAt  DateTime?
  agendadoAt DateTime?
  estado     String          @default("pendiente") // pendiente | agendada | procesando | finalizada
  pausada    Boolean         @default(false)
  templateId Int?
  jobId      String?
  template   TemplateEmail?  @relation(fields: [templateId], references: [id])
  contactos  ContactoEmail[]
  reportes   ReporteEmail[]
  archivada  Boolean         @default(false)
  config     Json?
  userId     Int
  @@map("CampañaEmail")
}

model ContactoEmail {
  id         Int            @id @default(autoincrement())
  email      String
  nombre     String?
  datos      Json? // variables del CSV
  campañaId Int
  campaña   CampañaEmail  @relation(fields: [campañaId], references: [id], onDelete: Cascade)
  reportes   ReporteEmail[]
  @@map("ContactoEmail")
}

model ReporteEmail {
  id               Int           @id @default(autoincrement())
  campañaId       Int
  contactoId       Int
  estado           String // 'enviado', 'fallido', etc.
  enviadoAt        DateTime?
  error            String? @db.Text
  asunto           String? // asunto final con variables reemplazadas
  html             String?       @db.MediumText // HTML renderizado con datos del contacto
  creadoAt         DateTime      
  trackingTok      String?       @unique // token por envío (se setea al enviar)
  primeroAbiertoAt DateTime?
  primeroClickAt   DateTime?  
  smtpMessageId    String?        @unique @db.VarChar(255)
  campaña          CampañaEmail @relation(fields: [campañaId], references: [id], onDelete: Cascade)
  contacto         ContactoEmail @relation(fields: [contactoId], references: [id], onDelete: Cascade)
  eventos          EmailEvento[]
  rebotes          EmailRebote[]

  @@index([campañaId])
  @@index([contactoId])
  @@map("ReporteEmail")
}

model Configuracion {
  id        Int      @id @default(autoincrement())
  userId    Int
  scope     String // Ej: 'whatsapp.envio', 'email.envio', etc.
  clave     String // Ej: 'batchSize', 'delayEntreMensajes'
  valor     String // Guardado como string por simplicidad
  updatedAt DateTime @updatedAt

  @@unique([userId, scope, clave])
  @@map("Configuracion")
}

model EmailEvento {
  id             Int             @id @default(autoincrement())
  reporteId      Int
  tipo           EmailEventoTipo // OPEN | CLICK
  urlDestino     String? // sólo para CLICK
  dominioDestino String? // sólo para CLICK (ej: "example.com")
  fecha          DateTime        

  // metadatos
  ip             String?
  userAgent      String?
  deviceFamily   String? // "Desktop" | "Mobile" | "Tablet" | "GenericPhone" | "Bot" | etc.
  osName         String?
  osVersion      String?
  browserName    String?
  browserVersion String?
  uaRaw          String?
  reporte        ReporteEmail @relation(fields: [reporteId], references: [id], onDelete: Cascade)

  @@index([reporteId, tipo, fecha])
  @@index([tipo, fecha])
  @@map("EmailEvento")
}

enum EmailEventoTipo {
  OPEN
  CLICK
}

model EmailRebote {
  id            Int           @id @default(autoincrement())
  reporteId     Int?          // <- ahora opcional
  fecha         DateTime      
  codigo        String?       @db.VarChar(32)   // 5.1.1 / 550 / etc.
  descripcion   String?       @db.Text          // motivo/diagnóstico
  raw           String?       @db.MediumText    // cuerpo/DSN (más grande)    
  correo        String?        @db.VarChar(320)  
  smtpMessageId String?       @db.VarChar(255)
  xAmsaSender   String?       @db.VarChar(512)
  reporte       ReporteEmail? @relation(fields: [reporteId], references: [id], onDelete: SetNull)

  @@index([reporteId, fecha])
  @@map("EmailRebote")
}

model EmailDesuscripciones {
  id            String   @id @default(cuid())
  tenantId      String
  email         String   // guardá el original por auditoría
  emailHash     String   // normalizado: trim + lowercase + hash (p.ej. sha256)
  scope         String   @default("global") // "global" o "campaign"
  campaignId    String   @default("")       // <— ya no es opcional; default vacío
  reason        String?  // "user_click", "admin_add", "list-unsubscribe", etc.
  source        String?  // "footer_link", "header_oneclick", "api", etc.
  createdAt     DateTime 

  @@index([tenantId, emailHash])
  @@unique([tenantId, emailHash, scope, campaignId])
  @@map("EmailDesuscripciones")
}

// ============================================================
// WhatsApp Business API (Meta) Module
// ============================================================

model WaApiConfig {
  id            Int      @id @default(autoincrement())
  phoneNumberId String   // Meta phone_number_id (ANI validado)
  wabaId        String   // WhatsApp Business Account ID
  token         String   @db.Text // token permanente
  verifyToken   String   // token para verificación del webhook
  appSecret     String?  @db.Text // App Secret de Meta para verificar firma del webhook
  activo        Boolean  @default(true)
  creadoAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@map("WaApiConfig")
}

model WaApiTemplate {
  id             Int            @id @default(autoincrement())
  metaNombre     String         @unique // nombre del template en Meta (actúa como ID)
  categoria      String         // MARKETING | UTILITY | AUTHENTICATION
  idioma         String         // es, es_AR, en_US, etc.
  estado         String         // APPROVED | PENDING | REJECTED | PAUSED
  componentes    Json           // raw components de la API de Meta
  buttonActions  Json?          // [{ payload: string, accion: "INBOX"|"BAJA"|"IGNORAR", enviarConfirmacion: bool }]
  sincronizadoAt DateTime
  creadoAt       DateTime       @default(now())
  campanias      WaApiCampaña[]
  @@map("WaApiTemplate")
}

model WaApiCampaña {
  id         Int             @id @default(autoincrement())
  nombre     String
  templateId Int?
  template   WaApiTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  estado     String          @default("pendiente") // pendiente | agendada | procesando | pausada | finalizada | error
  pausada    Boolean         @default(false)
  archivada  Boolean         @default(false)
  jobId      String?
  agendadoAt DateTime?
  enviadoAt  DateTime?
  createdAt  DateTime        @default(now())
  config     Json?           // { variableMapping: {...}, delayMs: number, batchSize: number }
  userId     Int
  contactos  WaApiContacto[]
  reportes   WaApiReporte[]
  @@map("WaApiCampaña")
}

model WaApiContacto {
  id        Int           @id @default(autoincrement())
  numero    String        // formato E.164: 5491112345678
  nombre    String?
  variables Json?         // { "1": "Juan", "2": "producto X" }
  campañaId Int
  campaña  WaApiCampaña @relation(fields: [campañaId], references: [id], onDelete: Cascade)
  reporte   WaApiReporte?
  @@map("WaApiContacto")
}

model WaApiReporte {
  id          Int           @id @default(autoincrement())
  campañaId  Int
  contactoId  Int           @unique
  numero      String
  waMessageId String?       @unique // wamid devuelto por Meta
  estado      String        @default("pendiente") // pendiente | sent | delivered | read | failed
  error       String?       @db.Text
  enviadoAt   DateTime?
  entregadoAt DateTime?
  leidoAt     DateTime?
  fallidoAt   DateTime?
  creadoAt    DateTime      @default(now())
  campaña    WaApiCampaña @relation(fields: [campañaId], references: [id], onDelete: Cascade)
  contacto    WaApiContacto @relation(fields: [contactoId], references: [id], onDelete: Cascade)
  @@index([campañaId])
  @@map("WaApiReporte")
}

enum EstadoConversacion {
  sin_asignar
  asignada
  resuelta
}

model WaApiConversacion {
  id              Int                @id @default(autoincrement())
  numero          String             @unique // teléfono del contacto en E.164
  nombre          String?            // nombre de display del contacto
  estado          EstadoConversacion @default(sin_asignar)
  asignadoAId     Int?               // FK a Usuario
  ultimoMensajeAt DateTime?
  ventana24hAt    DateTime?          // timestamp del último mensaje entrante (ventana vence 24h después)
  creadoAt        DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  mensajes        WaApiMensaje[]
  @@index([asignadoAId])
  @@index([estado])
  @@map("WaApiConversacion")
}

model WaApiMensaje {
  id             Int               @id @default(autoincrement())
  conversacionId Int
  conversacion   WaApiConversacion @relation(fields: [conversacionId], references: [id], onDelete: Cascade)
  waMessageId    String?           @unique
  fromMe         Boolean           // true = enviado por asesor, false = recibido del contacto
  tipo           String            // text | button | image | document | audio | video
  contenido      Json              // { text?, buttonPayload?, buttonText?, mediaUrl?, caption?, mimeType? }
  status         String            @default("sent") // sent | delivered | read
  timestamp      DateTime
  creadoAt       DateTime          @default(now())
  @@index([conversacionId, timestamp])
  @@map("WaApiMensaje")
}

model WaApiBaja {
  id                  Int      @id @default(autoincrement())
  numero              String   @unique
  campañaId          Int?
  campañaNombre      String?
  templateNombre      String?
  buttonPayload       String?
  confirmacionEnviada Boolean  @default(false)
  creadoAt            DateTime @default(now())
  @@map("WaApiBaja")
}

enum TipoTareaProgramada {
  REPORTE_EMAIL_DIARIO
}

enum EstadoEjecucionTarea {
  queued
  running
  completed
  failed
  retrying
}

model TareaProgramada {
  id              Int                     @id @default(autoincrement())
  nombre          String
  tipo            TipoTareaProgramada
  habilitada      Boolean                 @default(true)
  expresionCron   String                  // ej: "0 8 * * *"
  zonaHoraria     String                  @default("America/Argentina/Buenos_Aires")
  // Config específica (extensible)
  // { "reportes": { "rebotes": true, "acciones": true }, "asuntoTpl": "...", "htmlTpl": "...", "s3Prefix": "daily/" }
  configuracion   Json
  destinatarios   Json                    // string[] como JSON
  reintentosMax   Int                     @default(3)
  backoffMs       Int                     @default(60000)
  ultimaEjecucion DateTime?
  proximaEjecucion DateTime?

  creadoPorUsuarioId Int?
  creadoEn        DateTime                @default(now())
  actualizadoEn   DateTime                @updatedAt

  ejecuciones     EjecucionTarea[]

  @@map("TareaProgramada")
}

model EjecucionTarea {
  id          Int                   @id @default(autoincrement())
  tareaId     Int
  tarea       TareaProgramada       @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  inicioEn    DateTime
  finEn       DateTime?
  estado      EstadoEjecucionTarea
  error       String?               @db.Text
  // ej: [{ "archivo":"rebotes_2025-09-26.csv", "bytes":12345, "s3Key":"daily/..."}]
  adjuntos    Json?
  logs        Json?

  @@index([tareaId])
  @@map("EjecucionTarea")
}